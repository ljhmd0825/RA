--- a/input/input_driver.c
+++ b/input/input_driver.c
@@ -21,6 +21,11 @@
 #include "libretro.h"
 #include <queues/message_queue.h>
 #include <streams/interface_stream.h>
+#ifdef __linux__
+#include <fcntl.h>
+#include <unistd.h>

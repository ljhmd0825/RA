+#endif
 #define _USE_MATH_DEFINES
 #include <math.h>
 #include <string/stdstring.h>
@@ -467,6 +472,101 @@ static const input_device_driver_t *input_joypad_init_first(void *data)
    return NULL;
 }
 
+/* ── sysfs rumble fallback for GPIO / motor / timed-vibrator devices ──
+ *
+ * Many embedded Linux handhelds have rumble motors wired to GPIO pins or
+ * sysfs-controlled motor drivers rather than exposed as Linux FF input
+ * devices.  This fallback writes directly to sysfs when the joypad
+ * driver's native rumble returns false.
+ *
+ * Set ONE of these env-var groups before launching RetroArch:
+ *   RUMBLE_SYSFS_PATH  - GPIO on/off  (e.g. /sys/class/gpio/gpio20/value)
+ *   RUMBLE_MOTOR_SCALE + RUMBLE_MOTOR_LEVEL - proportional motor
+ *   RUMBLE_TIMED_PATH  - timed vibrator (e.g. /sys/.../vibrator/enable)
+ */
+#ifdef __linux__
+enum sysfs_rumble_type { SR_NONE, SR_GPIO, SR_MOTOR, SR_TIMED };
+
+static enum sysfs_rumble_type sr_mode   = SR_NONE;
+static const char *sr_path              = NULL;
+static const char *sr_motor_scale       = NULL;
+static const char *sr_motor_level       = NULL;
+static bool        sr_probed            = false;
+
+static void sr_write(const char *path, const char *val)
+{
+   int fd = open(path, O_WRONLY);
+   if (fd >= 0)
+   {
+      int unused __attribute__((unused)) = write(fd, val, strlen(val));
+      close(fd);
+   }
+}
+
+static void sr_probe(void)
+{
+   const char *p;
+   sr_probed = true;
+
+   if ((p = getenv("RUMBLE_SYSFS_PATH")) != NULL && *p)
+   {
+      sr_path = p;
+      sr_mode = SR_GPIO;
+      return;
+   }
+
+   if ((p = getenv("RUMBLE_MOTOR_SCALE")) != NULL && *p)
+   {
+      const char *l = getenv("RUMBLE_MOTOR_LEVEL");
+      if (l && *l)
+      {
+         sr_motor_scale = p;
+         sr_motor_level = l;
+         sr_mode = SR_MOTOR;
+         return;
+      }
+   }
+
+   if ((p = getenv("RUMBLE_TIMED_PATH")) != NULL && *p)
+   {
+      sr_path = p;
+      sr_mode = SR_TIMED;
+      return;
+   }
+}
+
+static bool sr_set(uint16_t strong, uint16_t weak)
+{
+   unsigned mag = strong > weak ? strong : weak;
+
+   switch (sr_mode)
+   {
+      case SR_GPIO:
+         sr_write(sr_path, mag > 0 ? "1" : "0");
+         return true;
+      case SR_MOTOR:
+         if (mag > 0)
+         {
+            char buf[16];
+            unsigned scale = (mag * 100u + 32767u) / 65535u;
+            if (scale < 5) scale = 5;
+            snprintf(buf, sizeof(buf), "%u", scale);
+            sr_write(sr_motor_scale, buf);
+            sr_write(sr_motor_level, "65535");
+         }
+         else
+            sr_write(sr_motor_level, "0");
+         return true;
+      case SR_TIMED:
+         sr_write(sr_path, mag > 0 ? "150" : "0");
+         return true;
+      default:
+         break;
+   }
+   return false;
+}
+#endif
+
 bool input_driver_set_rumble(
          unsigned port, unsigned joy_idx,
          enum retro_rumble_effect effect, uint16_t strength)
@@ -487,6 +587,30 @@ bool input_driver_set_rumble(
    if (sec_joypad     && sec_joypad->set_rumble)
       rumble_state = sec_joypad->set_rumble(joy_idx, effect, strength);
 
+#ifdef __linux__
+   if (!rumble_state)
+   {
+      static uint16_t fb_strong, fb_weak;
+
+      if (!sr_probed)
+         sr_probe();
+
+      if (sr_mode != SR_NONE)
+      {
+         switch (effect)
+         {
+            case RETRO_RUMBLE_STRONG:
+               fb_strong = strength;
+               break;
+            case RETRO_RUMBLE_WEAK:
+               fb_weak = strength;
+               break;
+         }
+         rumble_state = sr_set(fb_strong, fb_weak);
+      }
+   }
+#endif
+
    return rumble_state;
 }
 
